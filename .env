# Environment for BASE_URL determination
# Format: stage or prod
# Examples:
#   POD=stage           - uses staging environment (https://odyssey.stage.edx.org/)
#   POD=prod            - uses production environment (https://www.edx.org/)
# If not specified, defaults to stage
POD=stage

# The base URL of the website to test (auto-determined by POD value)
# For local mock server testing, use: http://localhost:3001
# For real endpoint validation, change this to the target URL (e.g. https://www.edx.org)
# This is dynamically set based on POD value during test execution
BASE_URL=https://odyssey.stage.edx.org/

# Choose whether to pull URLs from the sitemap (true) or fallback to manual URLs file (false).
# NOTE: content validators (seo, header, footer, semantic) load each page in a real browser,
# so running them across a full sitemap (thousands of URLs) is slow. Use USE_SITEMAP=false with
# a curated URLS_FILE for fast, representative runs; flip to true for an exhaustive crawl.
USE_SITEMAP=false
SITEMAP_PATH=/sitemap.xml
URLS_FILE=config/urls.json

# Custom report format produced in test-results/. Options (case-insensitive):
#   md    -> per-category Markdown files (default): *-validation-report.md
#   excel -> a single Excel workbook: validation-report.xlsx (one sheet per validator + Summary)
#   both  -> emit both formats
# The built-in Playwright "list" and "html" reporters always run in addition to this.
REPORT_FORMAT=excel

# Comma-separated list of active validators to run.
# Available: health, seo, header, footer, semantic
# (semantic = deterministic semantic-HTML-structure checks: headings, landmarks, media,
#  links, forms, tables, ARIA/ID integrity, interactive & list markup)
ACTIVE_VALIDATORS=health,seo,footer,header,semantic

# (Optional) Restrict which semantic SECTIONS run. Comma-separated, case-insensitive.
# Defaults to ALL sections when unset. Available sections (defined by SEMANTIC_SECTION_REGISTRY
# in validations/semantic.validator.ts):
#   document, headings, landmarks, media, links, forms, tables, ariaIntegrity, markup
# Example (run only heading, landmark, and ARIA/ID sections):
# ACTIVE_SEMANTIC_CHECKS=headings,landmarks,ariaIntegrity
#
# To toggle INDIVIDUAL rules within a section, flip that rule's boolean flag in
# `semanticDefaults` (config/page-validation.config.ts) or via a per-URL `semantic` override.
NAVIGATION_URLS_FILE=page_navigation_urls.csv

# Filter navigation validation by label
# Format: comma-separated label values or 'all'
# Examples:
#   NAVIGATION_LABEL=Learn           - validates only rows with label="Learn"
#   NAVIGATION_LABEL=Learn,Become    - validates only rows with labels "Learn" and "Become"
#   NAVIGATION_LABEL=all             - validates all rows (default)
NAVIGATION_LABEL=Degrees,Learn,Become

# Maximum number of URLs to test per label
# Format: positive integer or omit for unlimited
# Examples:
#   MAX_TESTS_PER_LABEL=5            - validates first 5 URLs per label
#   MAX_TESTS_PER_LABEL=10           - validates first 10 URLs per label
#   (omitted)                        - no limit, validates all selected URLs
# When combined with NAVIGATION_LABEL:
#   NAVIGATION_LABEL=Learn,Become and MAX_TESTS_PER_LABEL=5
#   Result: 5 URLs from Learn + 5 URLs from Become = 10 URLs total
MAX_TESTS_PER_LABEL=10
#SCREENSHOT_ON_FAILURE=true


